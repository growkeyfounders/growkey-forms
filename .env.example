PORT=5174

# Production storage. Leave empty locally to use data/submissions.json.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_TABLE=growkey_form_submissions

# Anon key (pública): el server la usa para validar JWTs contra Supabase Auth.
SUPABASE_ANON_KEY=your-anon-key

# Frontend (Vite las inyecta en el build): login y sesión de la SPA.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Keep false in production unless you intentionally want the admin "Limpiar"
# action to delete Supabase rows.
ALLOW_ADMIN_DELETE=false
